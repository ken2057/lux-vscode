{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Lux (LUcid eXpect scripting)",
    "scopeName": "source.lux",
    "fileTypes": [".lux", ".luxinc"],
    "patterns": [
        { "include": "#comment" },
        { "include": "#doc-short" },
        { "include": "#doc-long" },
        { "include": "#config" },
        { "include": "#define-variables" },
        { "include": "#use-variable" },
        { "include": "#shell" },
        { "include": "#progress" },
        { "include": "#timeout" },
        { "include": "#sleep" },
        { "include": "#include" },
        { "include": "#macro" },
        { "include": "#invoke" },
        { "include": "#cleanup" },
        { "include": "#!" },
        { "include": "#block-!" },
        { "include": "#??-???" },
        { "include": "#block-??-???" },
        { "include": "#?+" },
        { "include": "#?" },
        { "include": "#block-?" },
        { "include": "#loop" },
        { "include": "#-" }
    ],
    "repository": {
        "comment": {
            "name": "comment.line.number-sign.lux",
            "match": "^\\s*#.*$"
        },
        "doc-short": {
            "begin": "^[\\s]*\\[(doc\\d*) +",
            "beginCaptures": {
                "1": {"name": "entity.name.tag.lux"}
            },
            "contentName": "entity.name.function.lux",
            "end": "\\]\\s*$"
        },
        "doc-long": {
            "begin": "^[\\s]*\\[(doc)\\s*\\]",
            "beginCaptures": {
                "1": {"name": "entity.name.tag.lux"}
            },
            "contentName": "string", 
            "end": "\\[(enddoc)\\]\\s*$",
            "endCaptures": {
                "1": {"name": "entity.name.tag.lux"}
            }
        },
        "config": {
            "begin": "^[\\s]*\\[(config) +([^=]+)(=)",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "keyword.control.lux"},
                "3": { "name": "punctuation.separator.key-value.lux" }
            },
            "contentName": "string", 
            "end": "\\]\\s*$",
            "endCaptures": {
                "1": {"name": "keyword.control.global.lux"}
            }
        },
        "define-variables": {
            "begin": "^[\\s]*\\[(global|local|my) +([^=\\]]+)(=?)",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "variable.lux"},
                "3": { "name": "punctuation.separator.key-value.lux" }
            },
            "patterns": [
                { "include": "#use-variable" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string", 
            "end": "\\]\\s*$",
            "endCaptures": {
                "1": {"name": "keyword.control.global.lux"}
            }
        },
        "use-variable": {
            "match": "(\\$?\\$\\{?)([\\w_]+)(\\}?)",
            "captures": {

                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "variable.lux"},
                "3": {"name": "keyword.control.global.lux"}
            }
        },
        "shell": {
            "begin": "^[\\s]*\\[(shell|endshell) ?",
            "beginCaptures": {
                "1": {"name": "entity.name.tag.lux"}
            },
            "patterns": [
                { "include": "#use-variable" }
            ],
            "contentName": "variable.language.lux",
            "end": "\\]"
        },
        "progress": {
            "begin": "^[\\s]*(\\[)(progress) +",
            "beginCaptures": {
                "2": {"name": "comment.line.block.lux"}
            },
            "patterns": [
                { "include": "#use-variable" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string", 
            "end": "(\\])\\s*$",
            "endCaptures": {
            }
        },
        "timeout": {
            "match": "^[\\s]*\\[(timeout) +(\\d+)\\]",
            "captures": {
                "1": {"name": "keyword.control.lux"},
                "2": {"name": "constant.numeric.lux"}
            }
        },
        "sleep": {
            "match": "^[\\s]*\\[(sleep) +(\\d+)\\]",
            "captures": {
                "1": {"name": "keyword.control.lux"},
                "2": {"name": "constant.numeric.lux"}
            }
        },
        "include": {
            "begin": "^[\\s]*\\[(include) ",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"}
            },
            "patterns": [
                { "include": "#use-variable" }
            ],
            "contentName": "string", 
            "end": "\\]\\s*$"
        },
        "macro": {
            "begin": "^[\\s]*\\[(macro) ([^\\s]+)( [^\\]]*)*\\]",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "entity.name.function.lux"},
                "3": {"name": "variable.lux"}
            },
            "patterns": [
                { "include": "source.lux" }
            ],
            "end": "\\[(endmacro)( ?[^\\s]+)?\\]\\s*$",
            "endCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "entity.name.function.lux"}
            }
        },
        "var-quote": {
            "begin": "[\"\\[\\(]",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "entity.name.function.lux"},
                "3": {"name": "variable.lux"}
            },
            "patterns": [
                { "include": "#use-variable" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string",
            "end": "[\"\\]\\)]"
        },
        "invoke": {
            "begin": "^[\\s]*\\[(invoke) ([^ \\]]+)",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "entity.name.function.lux"},
                "3": {"name": "variable.lux"}
            },
            "patterns": [
                { "include": "#var-quote" },
                { "include": "#use-variable" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string",
            "end": "\\]\\s*"
        },
        "cleanup": {
            "begin": "^[\\s]*\\[(cleanup) ?",
            "beginCaptures": {
                "1": {"name": "entity.name.tag.lux"}
            },
            "contentName": "string",
            "end": "\\]\\s*"
        },
        "!": {
            "begin": "^[\\s]*([!~])",
            "beginCaptures": {
                "1": {"name": "storage.type.lux"}
            },
            "patterns": [
                { "include": "#use-variable" },
                { "include": "#source.js.regexp" }
            ],
            "contentName": "string", 
            "end": "$"
        },
        "block-!": {
            "begin": "^[\\s]*(\"{3}[!~])",
            "beginCaptures": {
                "1": {"name": "storage.type.block-??.lux"}
            },
            "patterns": [
                { "include": "#use-variable" }
            ],
            "contentName": "string", 
            "end": "(\"{3})",
            "endCaptures": {
                "1": {"name": "storage.type.block-??.lux"}
            }
        },
        "??-???": {
            "begin": "^[\\s]*(\\?{2,3})",
            "beginCaptures": {
                "1": {"name": "storage.type.??.lux"}
            },
            "patterns": [
                { "include": "#use-variable" }
            ],
            "contentName": "string", 
            "end": "$"
        },
        "block-??-???": {
            "begin": "^[\\s]*(\"{3}\\?{2,3})",
            "beginCaptures": {
                "1": {"name": "storage.type.block-??.lux"}
            },
            "patterns": [
                { "include": "#use-variable" }
            ],
            "contentName": "string", 
            "end": "(\"{3})",
            "endCaptures": {
                "1": {"name": "storage.type.block-??.lux"}
            }
        },
        "?": {
            "begin": "^[\\s]*(\\?\\+?)",
            "beginCaptures": {
                "1": {"name": "storage.type.?.lux"}
            },
            "patterns": [
                { "include": "#use-variable" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string", 
            "end": "$"
        },
        "block-?": {
            "begin": "^[\\s]*(\"{3}\\?)",
            "beginCaptures": {
                "1": {"name": "storage.type.block-?.lux"}
            },
            "patterns": [
                { "include": "#use-variable" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string", 
            "end": "(\"{3})",
            "endCaptures": {
                "1": {"name": "storage.type.block-?.lux"}
            }
        },
        "loop-break-pattern": {
            "begin": "^\\s*(@)",
            "beginCaptures": {
                "1": {"name": "storage.type.lux"}
            },
            "patterns": [
                { "include": "#use-variable" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string", 
            "end": "$"
        },
        "loop": {
            "begin": "^[\\s]*\\[(loop) ([^\\s]+)( [^\\]]*)*\\]",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "constant.numeric.lux"},
                "3": {"name": "variable.lux"}
            },
            "patterns": [
                { "include": "#loop-break-pattern" },
                { "include": "source.lux" }
            ],
            "end": "\\[(endloop)( .*)?\\]",
            "endCaptures": {
                "1": {"name": "keyword.control.global.lux"}
            }
        },
        "-": {
            "begin": "^\\s*(-)",
            "beginCaptures": {
                "1": {"name": "storage.type.lux"}
            },
            "patterns": [
                { "include": "#use-variable" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string", 
            "end": "$",
            "name": "markup.italic"
        }
    }
}