{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Lux (LUcid eXpect scripting)",
    "scopeName": "source.lux",
    "fileTypes": [".lux", ".luxinc"],
    "patterns": [
        { "include": "#comment" },
        { "include": "#doc_short" },
        { "include": "#doc_long" },
        { "include": "#config" },
        { "include": "#define_variables" },
        { "include": "#buildin_lux_variable" },
        { "include": "#variable_in_bracket" },
        { "include": "#use_variable" },
        { "include": "#shell" },
        { "include": "#progress" },
        { "include": "#timeout" },
        { "include": "#sleep" },
        { "include": "#include" },
        { "include": "#macro" },
        { "include": "#invoke" },
        { "include": "#cleanup" },
        { "include": "#!" },
        { "include": "#!_block" },
        { "include": "#??_???" },
        { "include": "#block_??_???" },
        { "include": "#?+" },
        { "include": "#?" },
        { "include": "#block_?" },
        { "include": "#block_\"" },
        { "include": "#block_@" },
        { "include": "#loop" },
        { "include": "#-" },
        { "include": "#+" },
        {
            "name": "invalid.illegal.lux",
            "match": "\\[.*\\]"
        }
    ],
    "repository": {
        "comment": {
            "name": "comment.line.number-sign.lux",
            "match": "#.*$"
        },
        "doc_short": {
            "begin": "^\\s*\\[(doc\\d*) +",
            "beginCaptures": {
                "1": {"name": "entity.name.tag.lux"}
            },
            "contentName": "string.doc_short.lux",
            "end": "\\]"
        },
        "doc_long": {
            "begin": "^\\s*\\[(doc)\\s*\\]",
            "beginCaptures": {
                "1": {"name": "entity.name.tag.lux"}
            },
            "contentName": "string.doc_long.lux",
            "end": "\\[(enddoc)\\]",
            "endCaptures": {
                "1": {"name": "entity.name.tag.lux"}
            }
        },
        "config": {
            "begin": "^\\s*\\[(config) +([^=]+)(=)",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "keyword.control.lux"},
                "3": { "name": "entity.name.section.lux" }
            },
            "contentName": "markup.bold",
            "end": "\\]\\s*$",
            "endCaptures": {
                "1": {"name": "keyword.control.global.lux"}
            }
        },
        "define_variables": {
            "begin": "^\\s*\\[(global|local|my) +([^=\\]]+)(=?)",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "variable.language.lux"},
                "3": { "name": "entity.name.section.lux" }
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" },
                { "include": "text.xml" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string",
            "end": "\\]\\s*$",
            "endCaptures": {
                "1": {"name": "keyword.control.global.lux"}
            }
        },
         "buildin_lux_variable": {
            "match": "(\\$\\{?)(LUX_SHELLNAME|LUX_START_REASON|LUX_TIMEOUT|LUX_FAIL_PATTERN|LUX_SUCCESS_PATTERN|PS1|_CTRL_C_|MAKE)(\\}?)",
            "captures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "markup.bold"},
                "3": {"name": "keyword.control.global.lux"}
            }
        },
        "use_variable": {
            "match": "(\\$?\\$\\{?)([\\w_-]+)(\\}?)",
            "captures": {

                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "variable.language.use_var.lux"},
                "3": {"name": "keyword.control.global.lux"}
            }
        },
        "shell": {
            "begin": "^[\\s]*\\[(shell|endshell|newshell) ",
            "beginCaptures": {
                "1": {"name": "entity.name.tag.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" }
            ],
            "contentName": "support.other.lux",
            "end": "\\]"
        },
        "progress": {
            "begin": "^[\\s]*(\\[)(progress) +",
            "beginCaptures": {
                "2": {"name": "comment.line.block.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string",
            "end": "(\\])\\s*$",
            "endCaptures": {
            }
        },
        "timeout": {
            "begin": "^\\s*\\[(timeout) *",
            "beginCaptures": {
                "1": { "name": "keyword.control.lux" }
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                {
                    "match": "\\b\\d+\\b",
                    "name": "constant.numeric.timeout.lux"
                },
                {
                    "match": "\\b.+\\b",
                    "name": "invalid.illegal.lux"
                }
            ],
            "end": "\\]\\s*$"
        },
        "sleep": {
            "begin": "^\\s*\\[(sleep) +",
            "beginCaptures": {
                "1": { "name": "keyword.control.lux" }
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                {
                    "match": "\\b\\d+\\b",
                    "name": "constant.numeric.sleep.lux"
                },
                {
                    "match": "\\b.+\\b",
                    "name": "invalid.illegal.lux"
                }
            ],
            "end": "\\]\\s*$"
        },
        "include": {
            "begin": "^[\\s]*\\[(include) ",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" }
            ],
            "contentName": "entity.name.section",
            "end": "\\]\\s*$"
        },
        "macro": {
            "begin": "^[\\s]*\\[(macro) ([^\\s]+)( [^\\]]*)*\\]",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "entity.name.function.lux"},
                "3": {"name": "variable.language.macro_var.lux"}
            },
            "patterns": [
                { "include": "source.lux" }
            ],
            "end": "\\[(endmacro)( [^\\s]+)?\\]\\s*$",
            "endCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "entity.name.function.lux"}
            }
        },
        "var-quote": {
            "begin": "[\"\\[\\(]",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "entity.name.function.lux"},
                "3": {"name": "variable.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string",
            "end": "[\"\\]\\)]"
        },
        "invoke": {
            "begin": "^[\\s]*\\[(invoke) ([^ \\]]+)",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "entity.name.function.lux"},
                "3": {"name": "variable.lux"}
            },
            "patterns": [
                { "include": "#var-quote" },
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string",
            "end": "\\]\\s*"
        },
        "cleanup": {
            "begin": "^[\\s]*\\[(cleanup) ?",
            "beginCaptures": {
                "1": {"name": "entity.name.tag.lux"}
            },
            "contentName": "string",
            "end": "\\]\\s*"
        },
        "!": {
            "begin": "^[\\s]*([!~])",
            "beginCaptures": {
                "1": {"name": "storage.type.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" }
            ],
            "contentName": "entity.name.section.!.lux",
            "end": "$"
        },
        "!-breakline": {
            "patterns": [
                {
                    "begin": "^[\\s]*(!)([^\\\\]+)\\\\s*$",
                    "beginCaptures": {
                        "1": {"name": "storage.type.lux"}
                    },
                    "patterns": [
                        { "include": "#buildin_lux_variable" },
                        { "include": "#use_variable" },
                        { "include": "#variable_in_bracket" }
                    ],
                    "contentName": "entity.name.section.!.lux",
                    "end": "\\\\\\s*$"
                },
                {
                    "begin": "^[\\s]*",
                    "beginCaptures": {
                        "1": {"name": "storage.type.lux"}
                    },
                    "patterns": [
                        { "include": "#buildin_lux_variable" },
                        { "include": "#use_variable" },
                        { "include": "#variable_in_bracket" }
                    ],
                    "contentName": "entity.name.section.!.lux",
                    "end": "\\\\"
                }
            ]
        },
        "!_block": {
            "begin": "^[\\s]*(\"{3}[!~])",
            "beginCaptures": {
                "1": {"name": "storage.type.block-!.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" }
            ],
            "contentName": "entity.name.section.!.lux",
            "end": "(\"{3})",
            "endCaptures": {
                "1": {"name": "storage.type.block-!.lux"}
            }
        },
        "??_???": {
            "begin": "^[\\s]*(\\?{2,3})",
            "beginCaptures": {
                "1": {"name": "storage.type.??.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" }
            ],
            "contentName": "string",
            "end": "$"
        },
        "block_??_???": {
            "begin": "^[\\s]*(\"{3}\\?{2,3})",
            "beginCaptures": {
                "1": {"name": "storage.type.block_??.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" }
            ],
            "contentName": "string",
            "end": "(\"{3})",
            "endCaptures": {
                "1": {"name": "storage.type.block_??.lux"}
            }
        },
        "?": {
            "begin": "^[\\s]*(\\?\\+?)",
            "beginCaptures": {
                "1": {"name": "storage.type.?.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string",
            "end": "$"
        },
        "block_?": {
            "begin": "^[\\s]*(\"{3}\\?)",
            "beginCaptures": {
                "1": {"name": "storage.type.block_?.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" },
                { "include": "text.xml" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string",
            "end": "(\"{3})",
            "endCaptures": {
                "1": {"name": "storage.type.block_?.lux"}
            }
        },
        "block_@": {
            "begin": "^[\\s]*(\"{3}\\@)",
            "beginCaptures": {
                "1": {"name": "storage.type.block_@.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" },
                { "include": "text.xml" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string",
            "end": "(\"{3})",
            "endCaptures": {
                "1": {"name": "storage.type.block_@.lux"}
            }
        },
        "block_\"": {
            "begin": "^\\s*(\"{3})$",
            "beginCaptures": {
                "1": {"name": "storage.type.block_\".start.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" },
                { "include": "text.xml" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string",
            "end": "^\\s*(\"{3})$",
            "endCaptures": {
                "1": {"name": "storage.type.block_\".end.lux"}
            }
        },
        "loop": {
            "begin": "^[\\s]*\\[(loop) ([^\\s]+)( [^\\]]*)*\\]",
            "beginCaptures": {
                "1": {"name": "keyword.control.global.lux"},
                "2": {"name": "constant.numeric.lux"},
                "3": {"name": "variable.lux"}
            },
            "end": "\\s*\\[(endloop)( .*)?\\]",
            "endCaptures": {
                "1": {"name": "keyword.control.global.lux"}
            },
            "patterns": [
                { "include": "#block_@" },
                {
                    "begin": "^\\s*(@)",
                    "beginCaptures": {
                        "1": {"name": "storage.type.lux"}
                    },
                    "patterns": [
                        { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                        { "include": "source.js.regexp" }
                    ],
                    "contentName": "string",
                    "end": "$"
                },
                {
                    "begin": "^\\s*(\"{3}@)",
                    "beginCaptures": {
                        "1": {"name": "storage.type.lux"}
                    },
                    "patterns": [
                        { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                        { "include": "source.js.regexp" }
                    ],
                    "contentName": "string",
                    "end": "(\"{3})"
                },
                { "include": "source.lux" }
            ]
        },
        "-": {
            "begin": "^\\s*(-)",
            "beginCaptures": {
                "1": {"name": "storage.type.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string",
            "end": "$",
            "name": "markup.italic"
        },
        "+": {
            "begin": "^\\s*(\\+)",
            "beginCaptures": {
                "1": {"name": "storage.type.lux"}
            },
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" },
                { "include": "#variable_in_bracket" },
                { "include": "source.js.regexp" }
            ],
            "contentName": "string",
            "end": "$",
            "name": "markup.bold"
        },
        "variable_in_bracket":{
            "begin": "\\(",
            "patterns": [
                { "include": "#buildin_lux_variable" },
                { "include": "#use_variable" }
            ],
            "end": "\\)"
        }
    }
}